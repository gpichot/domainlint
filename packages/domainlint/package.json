{
  "name": "domainlint",
  "description": "Linter for domain-based repository",
  "version": "0.7.0",
  "author": "Gabriel Pichot",
  "bin": {
    "domainlint": "./bin/run.js"
  },
  "bugs": "https://github.com/gpichot/domainlint/issues",
  "dependencies": {
    "@oclif/core": "^4.9.0",
    "@oclif/plugin-help": "^6.2.38",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.4",
    "oxc-parser": "^0.121.0",
    "oxc-resolver": "^11.19.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4.1.16",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "memfs": "^4.56.11",
    "oclif": "^4.22.91",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json",
    "./schema.json"
  ],
  "homepage": "https://github.com/gpichot/domainlint",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "domainlint",
    "dirname": "domainlint",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  },
  "repository": "gpichot/domainlint",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b && node scripts/generate-schema.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
