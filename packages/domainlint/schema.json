{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "rootDir": {
      "type": "string"
    },
    "srcDir": {
      "type": "string"
    },
    "featuresDir": {
      "type": "string"
    },
    "barrelFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\..*"
      }
    },
    "tsconfigPath": {
      "type": "string"
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "includeDynamicImports": {
      "type": "boolean"
    },
    "rulesFile": {
      "type": "string"
    },
    "overrides": {
      "type": "object",
      "properties": {
        "global": {
          "type": "object",
          "properties": {
            "rules": {
              "type": "object",
              "properties": {
                "import-cycles": {
                  "type": "string",
                  "enum": ["off", "warn", "error"]
                },
                "cross-feature-imports": {
                  "type": "string",
                  "enum": ["off", "warn", "error"]
                },
                "no-external-feature-imports": {
                  "type": "string",
                  "enum": ["off", "warn", "error"]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "features": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "rules": {
                "type": "object",
                "properties": {
                  "import-cycles": {
                    "type": "string",
                    "enum": ["off", "warn", "error"]
                  },
                  "cross-feature-imports": {
                    "type": "string",
                    "enum": ["off", "warn", "error"]
                  },
                  "no-external-feature-imports": {
                    "type": "string",
                    "enum": ["off", "warn", "error"]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "packageRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "deny": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["from", "deny"],
        "additionalProperties": false
      }
    },
    "packageRulesFile": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
